  - m_Id: 21545642008576
    m_Localized: CONTINUAR
    m_Metadata:
      m_Items: []
  - m_Id: 21657541844992
    m_Localized: 'Move a escavadora con [WASD]'
    m_Metadata:
      m_Items: []
  - m_Id: 22069615435776
    m_Localized: "Recolle vetas de carb\xF3n coa [E]"
    m_Metadata:
      m_Items: []
  - m_Id: 22355193012224
    m_Localized: "Entrega a carga na central t\xE9rmica"
    m_Metadata:
      m_Items: []
  - m_Id: 22682076094464
    m_Localized: "\rEvita os obst\xE1culos! Gas, Aceite e Rocas"
    m_Metadata:
      m_Items: []
  - m_Id: 23038390607872
    m_Localized: "\rPulsa [T] se te atascas. Frea mantendo [Espazo]"
    m_Metadata:
      m_Items: []
  - m_Id: 23405568368640
    m_Localized: FIN DO XOGO
    m_Metadata:
      m_Items: []
  - m_Id: 23499562721280
    m_Localized: "Puntuaci\xF3n"
    m_Metadata:
      m_Items: []
  - m_Id: 23652734509056
    m_Localized: REINICIAR
    m_Metadata:
      m_Items: []
  - m_Id: 23745839669248
