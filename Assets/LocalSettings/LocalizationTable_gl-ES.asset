    m_Metadata:
      m_Items: []
  - m_Id: 25321601933312
    m_Localized: "PRECAUCI\xD3N: Detectouse unha fuga de gas t\xF3xico"
    m_Metadata:
      m_Items: []
  - m_Id: 25303159578624
    m_Localized: "PRECAUCI\xD3N: Derramouse aceite esvarad\xEDzo"
    m_Metadata:
      m_Items: []
  - m_Id: 25277909868544
    m_Localized: "PRECAUCI\xD3N: Ocorreu un derrube"
    m_Metadata:
      m_Items: []
  - m_Id: 26407104585728
    m_Localized: "Dep\xF3sito cheo. Entrega o carb\xF3n na central"
    m_Metadata:
      m_Items: []
  - m_Id: 26689859395584
    m_Localized: "Dep\xF3sito baleiro. Recolle carb\xF3n na mina"
    m_Metadata:
      m_Items: []
  - m_Id: 27008236429312
    m_Localized: "Carb\xF3n depositado! Engadindo tempo l\xEDmite"
    m_Metadata:
      m_Items: []
  - m_Id: 299206780035072
    m_Localized: "PUNTUACI\xD3NS"
