    m_Metadata:
      m_Items: []
  - m_Id: 1198817078059008
    m_Localized: "Recolocado. Dep\xF3sito reducido \xE1 metade"
    m_Metadata:
      m_Items: []
  - m_Id: 1398459292098560
    m_Localized: "Novo R\xE9cord!"
    m_Metadata:
      m_Items: []
  - m_Id: 1399867911348224
    m_Localized: "Rexistra a t\xFAa puntuaci\xF3n"
